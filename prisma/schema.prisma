generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  /// Clerk user id (user_…); koppelt app-data aan Clerk-sessie.
  clerkId       String?   @unique
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  /// Microsoft Graph OAuth tokens (Outlook/Teams kalenderintegratie)
  msAccessToken        String?
  msRefreshToken       String?
  msTokenExpiresAt     DateTime?
  /// Graph change-notification subscription (real-time kalender-webhook)
  msSubscriptionId     String?
  msSubscriptionExpiry DateTime?

  meetings   Meeting[]
  templates  Template[]
  folders    Folder[]
  projects   Project[]
  employees  Employee[]
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Project {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Standaard overlegtype (template) voor nieuwe meetings in dit project
  templateId           String?
  /// MS Planner koppeling
  plannerPlanId        String?
  plannerBucketId      String?
  /// SharePoint documentopslag
  sharePointSiteId     String?
  sharePointDriveId    String?
  sharePointFolderPath String?
  /// Teams Incoming Webhook URL voor notificaties
  teamsWebhookUrl      String?

  userId        String
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  template      Template?             @relation("ProjectTemplate", fields: [templateId], references: [id], onDelete: SetNull)
  meetings      Meeting[]
  actionItems   ActionItem[]
  participants  ProjectParticipant[]
}

model Meeting {
  id          String    @id @default(cuid())
  title       String
  status      String    @default("draft")
  platform    String?
  startedAt   DateTime?
  endedAt     DateTime?
  duration    Int?
  audioPath   String?
  scheduledAt DateTime?
  /// JSON: AgendaItem[] – agenda voor geplande vergaderingen
  agenda      String?
  /// Outlook Graph event-id (voor bidirectionele sync)
  outlookEventId  String?
  /// Teams-vergader-URL (ingevuld na aanmaken Outlook-event met Teams)
  teamsJoinUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, outlookEventId])

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId   String?
  folder     Folder?   @relation(fields: [folderId], references: [id])
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  templateId String?
  template   Template? @relation(fields: [templateId], references: [id])

  transcript   Transcript?
  notes        Notes?
  actionItems  ActionItem[]
  chatMessages ChatMessage[]
  participants Participant[]
  tags         MeetingTag[]
}

model Transcript {
  id        String   @id @default(cuid())
  meetingId String   @unique
  content   String
  segments  String
  /// True zolang alleen live browser-tekst staat; Whisper vervangt daarna inhoud.
  isProvisional Boolean @default(false)
  language  String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model Notes {
  id        String   @id @default(cuid())
  meetingId String   @unique
  content   String
  summary   String?
  rawNotes  String?
  /// JSON object: per-Word-veld tekst ({{samenvatting}}, …) voor huisstijl-export
  wordPlaceholders String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model ActionItem {
  id          String    @id @default(cuid())
  /// Meeting waar het punt vandaan komt; null = alleen nog gekoppeld aan project (bv. na verwijderen meeting).
  meetingId   String?
  /// Gedeelde actielijst voor alle meetings in dit project.
  projectId   String?
  title       String
  description String?
  assignee    String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  /// MS Planner task ID voor bidirectionele sync
  plannerTaskId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  meeting Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([meetingId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  meetingId String
  role      String
  content   String
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model Participant {
  id         String  @id @default(cuid())
  meetingId  String
  name       String
  email      String?
  role       String?
  employeeId String?

  meeting  Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}

model Employee {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants Participant[]

  @@unique([userId, email])
  @@index([userId])
}

model ProjectParticipant {
  id        String  @id @default(cuid())
  projectId String
  name      String
  email     String?
  role      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Template {
  id                      String   @id @default(cuid())
  name                    String
  description             String?
  content                 String
  /// Optioneel: hoe actiepunten geëxtraheerd moeten worden (velden, prioriteit). Leeg = AI kiest zelf.
  actionItemsInstructions String?
  /// Relatief pad naar .docx op schijf (uploads/), voor export met huisstijl. Null = geen Word-sjabloon.
  docxPath                String?
  /// JSON-array van placeholder-namen uit het .docx (zonder {{ }}), bv. ["samenvatting","besluiten"]
  docxPlaceholderKeys     String?
  isDefault               Boolean  @default(false)
  isPublic    Boolean  @default(false)
  /// Overlegtype-velden — doel, standaard agenda en AI-context
  goal                  String?
  defaultAgenda         String?
  aiContextInstructions String?
  outputFocus           String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  meetings           Meeting[]
  defaultForProjects Project[] @relation("ProjectTemplate")
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  meetings Meeting[]
}

model Tag {
  id       String       @id @default(cuid())
  name     String
  color    String       @default("#6366f1")
  meetings MeetingTag[]
}

model MeetingTag {
  meetingId String
  tagId     String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([meetingId, tagId])
}
